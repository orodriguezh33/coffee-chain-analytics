# -- AWS -----------------------------------------------------------
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# -- S3 ------------------------------------------------------------
S3_BUCKET=coffee-chain-datalake
S3_BRONZE=s3://coffee-chain-datalake/bronze
S3_SILVER=s3://coffee-chain-datalake/silver
S3_GOLD=s3://coffee-chain-datalake/gold

# -- Athena --------------------------------------------------------
ATHENA_DATABASE=coffee_chain
ATHENA_WORKGROUP=primary
ATHENA_RESULTS=s3://coffee-chain-datalake/athena-results/

# -- Airflow (local) ----------------------------------------------
# Usa valores fuertes en local y no los compartas.
AIRFLOW_DB_PASSWORD=change_me_db_password
AIRFLOW_FERNET_KEY=replace_with_generated_fernet_key
AIRFLOW_SECRET_KEY=replace_with_random_secret_key
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=change_me_admin_password

# -- Redshift Serverless -------------------------------------------
REDSHIFT_HOST=your-workgroup.account.region.redshift-serverless.amazonaws.com
REDSHIFT_PORT=5439
REDSHIFT_DB=coffee_chain
REDSHIFT_USER=admin
REDSHIFT_PASSWORD=your_password_here
REDSHIFT_IAM_ROLE=arn:aws:iam::123456789012:role/RedshiftS3Role

# -- dbt -----------------------------------------------------------
DBT_PROFILES_DIR=/app/dbt
DBT_TARGET=dev
