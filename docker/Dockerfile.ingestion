# docker/Dockerfile.ingestion
# Imagen base para todos los scripts Python del proyecto
# (ingesta, quality gates, carga Redshift)

FROM python:3.11-slim

RUN apt-get update && apt-get install -y \
    curl \
    gcc \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.ingestion.txt .
RUN pip install --no-cache-dir -r requirements.ingestion.txt

CMD ["python", "--version"]
